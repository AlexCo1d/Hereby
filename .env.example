# Copy to `.env` and fill in. All EXPO_PUBLIC_* vars are bundled into the app
# (safe for the anon key — it's RLS-gated; never put the service_role key here).

# Data source: "mock" (default, in-memory) or "supabase".
EXPO_PUBLIC_DATA_SOURCE=mock

# Supabase project (only needed when EXPO_PUBLIC_DATA_SOURCE=supabase)
# URL = your project URL; ANON_KEY = the publishable key (sb_publishable_...).
# NEVER put the secret key (sb_secret_...) here — it's server-only.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# DEV ONLY: treat any verified email as a full (non-browse-only) user, so you
# can test posting/ordering with a personal inbox (QQ/Gmail) without an .edu
# address. Leave unset for production behaviour.
# EXPO_PUBLIC_ALLOW_ANY_EMAIL=true
